generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SiteData {
  id String @id @default("singleton")
  
  heroTitle String
  heroSubtitle String
  heroCtaText String

  footerHeadline1 String
  footerHeadline2 String
  footerCtaTitle String
  footerCtaSubtitle String
  footerCtaButton String
}

model TimelineItem {
  id String @id @default(uuid())
  order Int
  number String
  title String
  description String
}

model Client {
  id String @id @default(uuid())
  order Int
  name String
}

model PortfolioItem {
  id String @id @default(uuid())
  order Int
  date String
  title String
  description String?
  imageUrl String?
  accentColor String?
}

model Testimonial {
  id String @id @default(uuid())
  order Int
  quote String
  author String
  role String
}
